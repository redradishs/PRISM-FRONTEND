{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-cache-first",
      "urls": [
        "https://api.prismgcccs.live/**",
        "https://prismapi2.onrender.com/**",
        "https://redprismai.vercel.app/**",
        "http://localhost:8000/**",
        "http://localhost:3000/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "1h",
        "timeout": "15s"
      }
    },
    {
      "name": "ai-api-bypass",
      "urls": [
        "https://api.studio.nebius.com/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 0,
        "maxAge": "0u",
        "timeout": "30s"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*__*",
    "!/**/*__*/**"
  ]
}
